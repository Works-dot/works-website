modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8090
externalPort = 3001

[[ports]]
localPort = 8091
externalPort = 3002

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 20022
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.development]
PREVIEW_CLIENT_URL = "https://81b234ea-07bf-4cff-b177-1f0b1b6faeb3-00-2lvzpt0idpdlw.spock.replit.dev"
